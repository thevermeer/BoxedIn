{
  "manifest_version": 3,
  "name": "BoxedIn",
  "version": "1.0.0",
  "description": "Blocks extension probes, LinkedIn telemetry (sensorCollect, li/track, realtime, tscp-serving, opaque tokens), protechts collector; optional empty.js redirect (see page-guard.js).",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page-guard.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}
